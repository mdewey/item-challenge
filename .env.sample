# Storage Configuration
# Set to "true" to use DynamoDB instead of in-memory storage
USE_DYNAMODB=false

# DynamoDB Configuration (required when USE_DYNAMODB=true)
DYNAMODB_TABLE_NAME=item-challenge-items-dev
AWS_REGION=us-east-2

# Optional: For DynamoDB Local development
# DYNAMODB_ENDPOINT=http://localhost:8000

# Server Configuration
PORT=3000

# Logging
LOG_LEVEL=debug
